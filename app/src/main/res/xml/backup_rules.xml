<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto Backup rules for Nightseed Bastion.
   Only the local Room (SQLite) game database is backed up to the user's own
   Google Drive so progress survives a phone change. No data leaves the device
   to any third party — this stays consistent with the published privacy policy.
   Applies to API 30 and below; API 31+ uses data_extraction_rules.xml.
-->
<full-backup-content>
    <include domain="database" path="nightseed_bastion_db" />
</full-backup-content>
