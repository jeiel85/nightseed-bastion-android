<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for API 31+ (Android 12 and above).
   Cloud backup: persist the local Room game database to the user's Google
   Drive so they can resume progress on a new device.
   Device transfer: include the same data when switching phones via the
   Android setup wizard.
   Consistent with the privacy policy — no data is sent to our servers.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="nightseed_bastion_db" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="nightseed_bastion_db" />
    </device-transfer>
</data-extraction-rules>
