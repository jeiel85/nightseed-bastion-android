; Engine configuration file.
;
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Nightseed Bastion"
config/description="Vertical mobile fortress-survival strategy. Build by day, defend by night."
config/version="0.1.0"
config/tags=PackedStringArray("strategy", "tower-defense", "mobile", "godot4", "pixel-art")
run/main_scene="res://scenes/boot/Boot.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="NightseedBastion"
config/features=PackedStringArray("4.2", "GL Compatibility")

[autoload]

AppConfig="*res://scripts/autoload/AppConfig.gd"
EventBus="*res://scripts/core/EventBus.gd"
SceneRouter="*res://scripts/autoload/SceneRouter.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"
DataRegistry="*res://scripts/autoload/DataRegistry.gd"
LocalizationService="*res://scripts/autoload/LocalizationService.gd"
AudioBus="*res://scripts/autoload/AudioBus.gd"
InputService="*res://scripts/autoload/InputService.gd"
RunManager="*res://scripts/autoload/RunManager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=360
window/size/window_height_override=640
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

ui_pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194305,"physical_keycode":0,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}

[internationalization]

locale/test=""
locale/fallback="en"

[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Hero"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="Building"
2d_physics/layer_5="Projectile"
2d_physics/layer_6="Trigger"

[physics]

common/physics_ticks_per_second=60
common/enable_pause_aware_picking=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.04, 0.04, 0.08, 1)
